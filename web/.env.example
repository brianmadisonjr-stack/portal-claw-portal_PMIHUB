# PM Intelligence Hub (Next.js) environment template
# Copy to .env.local and fill in values (do NOT commit .env.local)

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only)
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / Postgres connection (e.g. Supabase Postgres)
DATABASE_URL=

# Square (optional / future)
SQUARE_ENV=sandbox
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
